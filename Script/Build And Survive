
-- GitHub Script
local scriptTable = {}

function scriptTable:Game(key)
    if key == "12345" then
        print("Success! Tama ang secret key.")
        -- Dito mo ilagay ang main code mo
    else
        print("Maling key!")
    end
end

return scriptTable -- MAHALAGA ITO: Kung wala ito, mag-eerror ang loader
