local function LoadGame(password, rawUrl, targetId, isEnabled)  
    if not isEnabled or game.PlaceId ~= targetId then return end
    local success, content = pcall(function()
        return game:HttpGet(rawUrl)
    end)
    if success then
        local run = loadstring(content)
        if run then
            local env = getfenv(run)
            env.PasaherongPassword = password
            run()
        end
    end
end


